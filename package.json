{
  "name": "void-exchange",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.0",
  "scripts": {
    "fmt": "prettier --write \"move-contracts/**/*.move\"",
    "fmt:ts": "prettier --write \"ts-scripts/**/*.ts\"",
    "fmt:check": "prettier --check \"move-contracts/**/*.move\" \"ts-scripts/**/*.ts\"",
    "lint": "sh scripts/lint-move.sh",
    "test:move": "sh scripts/test-move.sh",
    "typecheck": "tsc --noEmit",
    "authorize-amm": "tsx ts-scripts/amm_extension/authorize-amm.ts"
  },
  "dependencies": {
    "@mysten/sui": "^2.0.0",
    "@noble/hashes": "^1.8.0",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@mysten/prettier-plugin-move": "^0.3.5",
    "@types/node": "^24.10.4",
    "prettier": "^3.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
