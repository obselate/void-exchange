# ============================================
# SUI NETWORK
# ============================================
SUI_NETWORK=localnet

# Custom RPC URL (optional, defaults based on network)
# SUI_RPC_URL=http://127.0.0.1:9000

# ============================================
# KEYS & ADDRESSES
# ============================================
ADMIN_ADDRESS=
SPONSOR_ADDRESSES=

ADMIN_PRIVATE_KEY=
PLAYER_A_PRIVATE_KEY=
PLAYER_B_PRIVATE_KEY=

# ============================================
# PACKAGE IDS (populated after deployment)
# ============================================
WORLD_PACKAGE_ID=
AMM_PACKAGE_ID=
AMM_ORIGINAL_PACKAGE_ID=
# AMMRegistry shared object (created by module init at publish time).
# `sui client object <id>` returns its `initial_shared_version` once known.
AMM_REGISTRY_ID=
AMM_REGISTRY_INITIAL_SHARED_VERSION=

# ============================================
# TENANT
# ============================================
TENANT=dev
